<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Fragment>
    <CustomAction
      Id="OxidVaultRegisterNativeMessaging"
      Directory="INSTALLDIR"
      Execute="immediate"
      Return="check"
      Impersonate="yes"
      ExeCommand="powershell.exe -NoProfile -ExecutionPolicy Bypass -Command &quot;$manifestDir = Join-Path $env:LOCALAPPDATA 'OxidVault\NativeMessaging'; New-Item -ItemType Directory -Force -Path $manifestDir | Out-Null; $manifestPath = Join-Path $manifestDir 'com.oxidvault.app.json'; $hostPath = '[INSTALLDIR]oxidvault-nmh.exe'; $hostPathJson = $hostPath.Replace('\', '\\'); $json = '{&quot;name&quot;:&quot;com.oxidvault.app&quot;,&quot;description&quot;:&quot;OxidVault Native Messaging Host&quot;,&quot;path&quot;:&quot;' + $hostPathJson + '&quot;,&quot;type&quot;:&quot;stdio&quot;,&quot;allowed_origins&quot;:[&quot;chrome-extension://belagnpfebgljfamjihdoinbcehingjd/&quot;]}'; Set-Content -Path $manifestPath -Value $json -Encoding utf8; foreach ($key in @('HKCU:\Software\Google\Chrome\NativeMessagingHosts\com.oxidvault.app', 'HKCU:\Software\Microsoft\Edge\NativeMessagingHosts\com.oxidvault.app')) { New-Item -Path $key -Force | Out-Null; Set-Item -Path $key -Value $manifestPath }&quot;" />

    <CustomAction
      Id="OxidVaultUnregisterNativeMessaging"
      Directory="INSTALLDIR"
      Execute="immediate"
      Return="ignore"
      Impersonate="yes"
      ExeCommand="powershell.exe -NoProfile -ExecutionPolicy Bypass -Command &quot;$manifestPath = Join-Path (Join-Path $env:LOCALAPPDATA 'OxidVault\NativeMessaging') 'com.oxidvault.app.json'; Remove-Item -Path 'HKCU:\Software\Google\Chrome\NativeMessagingHosts\com.oxidvault.app' -Recurse -Force -ErrorAction SilentlyContinue; Remove-Item -Path 'HKCU:\Software\Microsoft\Edge\NativeMessagingHosts\com.oxidvault.app' -Recurse -Force -ErrorAction SilentlyContinue; Remove-Item -Path $manifestPath -Force -ErrorAction SilentlyContinue&quot;" />
  </Fragment>

  <Fragment>
    <InstallExecuteSequence>
      <Custom Action="OxidVaultRegisterNativeMessaging" After="InstallFiles">NOT REMOVE</Custom>
      <Custom Action="OxidVaultUnregisterNativeMessaging" Before="RemoveFiles">REMOVE=&quot;ALL&quot;</Custom>
    </InstallExecuteSequence>
  </Fragment>
</Wix>
