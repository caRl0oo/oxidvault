{
  "manifest_version": 3,
  "name": "OxidVault",
  "version": "0.3.0",
  "description": "Sicherer Passwort-Manager für dein Unternehmen.",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": ["nativeMessaging"],
  "action": {
    "default_title": "OxidVault",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
