<?xml version="1.0" encoding="utf-8"?><wixObject version="3.0.2002.0" xmlns="http://schemas.microsoft.com/wix/2006/objects"><section type="fragment"><table name="CustomAction"><row sourceLineNumber="e:\dev\OxidVault\src-tauri\wix\native_messaging.wxs*4"><field>OxidVaultRegisterNativeMessaging</field><field>34</field><field>INSTALLDIR</field><field>powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "$manifestDir = Join-Path $env:LOCALAPPDATA 'OxidVault\NativeMessaging'; New-Item -ItemType Directory -Force -Path $manifestDir | Out-Null; $manifestPath = Join-Path $manifestDir 'com.oxidvault.app.json'; $hostPath = '[INSTALLDIR]oxidvault-nmh.exe'; $hostPathJson = $hostPath.Replace('\', '\\'); $json = '{"name":"com.oxidvault.app","description":"OxidVault Native Messaging Host","path":"' + $hostPathJson + '","type":"stdio","allowed_origins":["chrome-extension://belagnpfebgljfamjihdoinbcehingjd/"]}'; Set-Content -Path $manifestPath -Value $json -Encoding utf8; foreach ($key in @('HKCU:\Software\Google\Chrome\NativeMessagingHosts\com.oxidvault.app', 'HKCU:\Software\Microsoft\Edge\NativeMessagingHosts\com.oxidvault.app')) { New-Item -Path $key -Force | Out-Null; Set-Item -Path $key -Value $manifestPath }"</field><field /></row><row sourceLineNumber="e:\dev\OxidVault\src-tauri\wix\native_messaging.wxs*12"><field>OxidVaultUnregisterNativeMessaging</field><field>98</field><field>INSTALLDIR</field><field>powershell.exe -NoProfile -ExecutionPolicy Bypass -Command "$manifestPath = Join-Path (Join-Path $env:LOCALAPPDATA 'OxidVault\NativeMessaging') 'com.oxidvault.app.json'; Remove-Item -Path 'HKCU:\Software\Google\Chrome\NativeMessagingHosts\com.oxidvault.app' -Recurse -Force -ErrorAction SilentlyContinue; Remove-Item -Path 'HKCU:\Software\Microsoft\Edge\NativeMessagingHosts\com.oxidvault.app' -Recurse -Force -ErrorAction SilentlyContinue; Remove-Item -Path $manifestPath -Force -ErrorAction SilentlyContinue"</field><field /></row></table><table name="WixSimpleReference"><row sourceLineNumber="e:\dev\OxidVault\src-tauri\wix\native_messaging.wxs*4"><field>Directory</field><field>INSTALLDIR</field></row><row sourceLineNumber="e:\dev\OxidVault\src-tauri\wix\native_messaging.wxs*12"><field>Directory</field><field>INSTALLDIR</field></row></table></section><section type="fragment"><table name="WixAction"><row sourceLineNumber="e:\dev\OxidVault\src-tauri\wix\native_messaging.wxs*23"><field>InstallExecuteSequence</field><field>OxidVaultRegisterNativeMessaging</field><field>NOT REMOVE</field><field /><field /><field>InstallFiles</field><field>0</field></row><row sourceLineNumber="e:\dev\OxidVault\src-tauri\wix\native_messaging.wxs*24"><field>InstallExecuteSequence</field><field>OxidVaultUnregisterNativeMessaging</field><field>REMOVE="ALL"</field><field /><field>RemoveFiles</field><field /><field>0</field></row></table><table name="WixSimpleReference"><row sourceLineNumber="e:\dev\OxidVault\src-tauri\wix\native_messaging.wxs*23"><field>CustomAction</field><field>OxidVaultRegisterNativeMessaging</field></row><row sourceLineNumber="e:\dev\OxidVault\src-tauri\wix\native_messaging.wxs*23"><field>WixAction</field><field>InstallExecuteSequence/InstallFiles</field></row><row sourceLineNumber="e:\dev\OxidVault\src-tauri\wix\native_messaging.wxs*24"><field>CustomAction</field><field>OxidVaultUnregisterNativeMessaging</field></row><row sourceLineNumber="e:\dev\OxidVault\src-tauri\wix\native_messaging.wxs*24"><field>WixAction</field><field>InstallExecuteSequence/RemoveFiles</field></row></table></section></wixObject>